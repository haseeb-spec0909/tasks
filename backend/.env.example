# Environment Configuration for TMC TimeIntel Backend

# Server
NODE_ENV=development
PORT=8080
DEBUG=false

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
CLOUD_SQL_CONNECTION=localhost:5432

# Database
DB_USER=timeintel
DB_PASSWORD=your-secure-password
DB_NAME=timeintel

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token
CALENDAR_WEBHOOK_TOKEN=your-webhook-verification-token

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key

# Vertex AI
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-pro

# ProjectFlow API
PROJECTFLOW_API_URL=https://projectflow.tmcltd.ai/api
PROJECTFLOW_API_KEY=your-projectflow-api-key

# Google Chat
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/your-space/messages

# Admin
ADMIN_EMAIL=haseeb@tmcltd.ai

# Application
ALLOWED_DOMAIN=tmcltd.ai
