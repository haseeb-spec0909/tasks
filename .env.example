# Environment
NODE_ENV=development
LOG_LEVEL=debug

# GCP Configuration
GCP_PROJECT_ID=tmcltd-timeintel
GCP_REGION=asia-south1

# Database Configuration
DATABASE_URL=postgresql://timeintel_app:password@localhost:5432/timeintel_db?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=timeintel_app
DB_PASSWORD=dev-password
DB_NAME=timeintel_db

# Redis Configuration
REDIS_URL=redis://:redis-dev-password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis-dev-password

# Backend API Configuration
API_PORT=8080
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:8080
API_TIMEOUT=30000

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8080
REACT_APP_GCP_PROJECT_ID=tmcltd-timeintel
REACT_APP_ENVIRONMENT=development

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# OAuth Configuration
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Google APIs
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
GOOGLE_CALENDAR_API_KEY=your-calendar-api-key
GOOGLE_TASKS_API_KEY=your-tasks-api-key

# ProjectFlow Integration
PROJECTFLOW_API_URL=https://projectflow-api.example.com
PROJECTFLOW_API_KEY=your-projectflow-api-key
PROJECTFLOW_WEBHOOK_SECRET=your-webhook-secret

# Google Chat Integration
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXXX/messages
GOOGLE_CHAT_BOT_NAME=TimeIntel Bot

# Firebase Configuration
FIREBASE_PROJECT_ID=tmcltd-timeintel
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=tmcltd-timeintel.firebaseapp.com
FIREBASE_DATABASE_URL=https://tmcltd-timeintel.firebaseio.com
FIREBASE_STORAGE_BUCKET=tmcltd-timeintel.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Vertex AI / Gemini Configuration
VERTEX_AI_PROJECT_ID=tmcltd-timeintel
VERTEX_AI_REGION=asia-south1
VERTEX_AI_MODEL=gemini-pro
VERTEX_AI_API_KEY=your-vertex-ai-key

# Notification Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@timeintel.tmcltd.ai

# Cloud Tasks Configuration
CLOUD_TASKS_PROJECT=tmcltd-timeintel
CLOUD_TASKS_QUEUE_LOCATION=asia-south1
CLOUD_TASKS_QUEUE_CALENDAR_WEBHOOK=calendar-webhook-queue
CLOUD_TASKS_QUEUE_PF_SYNC=pf-sync-queue
CLOUD_TASKS_QUEUE_NOTIFICATION=notification-queue
CLOUD_TASKS_QUEUE_SCHEDULING=scheduling-queue

# Cloud Scheduler Configuration
SCHEDULER_AUTH_TOKEN=your-scheduler-auth-token

# Analytics Configuration
ANALYTICS_ENABLED=false
ANALYTICS_KEY=your-analytics-key
MIXPANEL_TOKEN=your-mixpanel-token

# Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# Feature Flags
FEATURE_PF_INTEGRATION=true
FEATURE_GOOGLE_CALENDAR=true
FEATURE_GOOGLE_TASKS=true
FEATURE_VOICE_COMMANDS=false
FEATURE_AI_INSIGHTS=true
FEATURE_ADVANCED_ANALYTICS=false

# Monitoring & Logging
DATADOG_API_KEY=your-datadog-api-key
DATADOG_ENABLED=false
HONEYCOMB_API_KEY=your-honeycomb-api-key
HONEYCOMB_ENABLED=false

# Development Tools
DEBUG=timeintel:*
MOCK_EXTERNAL_APIS=false
ENABLE_PROFILING=false

# Timezone Configuration
DEFAULT_TIMEZONE=Asia/Karachi
SUPPORT_TIMEZONES=Asia/Karachi,UTC,America/New_York,Europe/London

# Docker & Compose
COMPOSE_PROJECT_NAME=timeintel
DB_PERSIST_VOLUME=postgres_data
REDIS_PERSIST_VOLUME=redis_data

# Scheduler Configuration
SCHEDULER_MIN_INSTANCES=1
SCHEDULER_MAX_INSTANCES=5
SCHEDULER_MEMORY=1Gi
SCHEDULER_CPU=2

# Backend Configuration
BACKEND_MIN_INSTANCES=1
BACKEND_MAX_INSTANCES=10
BACKEND_MEMORY=512Mi
BACKEND_CPU=1

# Admin Configuration
ADMIN_EMAIL=haseeb@tmcltd.ai
SUPPORT_EMAIL=support@tmcltd.ai

# Feature Configuration
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_REQUEST_VALIDATION=true
ENABLE_CORS=true

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
ENABLE_DISTRIBUTED_CACHE=true
